{
  "projectName": "RegressProof Fixture SwiftPM macOS",
  "baselineRef": "HEAD~1",
  "checks": {
    "commandTimeoutMs": 30000,
    "quick": [
      "swift build"
    ],
    "full": [
      "swift test"
    ]
  },
  "reports": {
    "defaultFormat": "json",
    "ciFailOn": [
      "confirmed_agent_fault"
    ]
  },
  "usage": {
    "mode": "estimated",
    "estimatedCostUsd": 0.02
  },
  "credits": {
    "enabled": true,
    "policy": "refund_estimated_cost_on_confirmed_agent_fault"
  }
}
